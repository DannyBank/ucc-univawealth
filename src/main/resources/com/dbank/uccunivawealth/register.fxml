<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
           minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0"
           styleClass="root-pane" stylesheets="@style/login.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.dbank.uccunivawealth.controller.RegisterController">

    <!-- Main split layout -->
    <HBox fillHeight="true" spacing="0">

        <!-- LEFT PANEL : gradient banner / image side -->
        <StackPane fx:id="leftPane" styleClass="left-panel" prefWidth="200.0"
                   HBox.hgrow="NEVER">

            <ImageView fx:id="leftImage" fitHeight="600.0" fitWidth="200.0"
                       preserveRatio="false" opacity="0.55" />

            <Region styleClass="left-overlay" />

            <VBox alignment="CENTER_LEFT" spacing="20" styleClass="left-content" maxWidth="320.0">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="30.0" top="40.0" />
                </padding>

                <Label styleClass="welcome-title" text="UnivaWEALTH" wrapText="true">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <Label styleClass="welcome-subtitle" wrapText="true"
                       text="Login and begin your life changing journey to wealth">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
            </VBox>

        </StackPane>

        <!-- RIGHT PANEL : login form -->
        <VBox alignment="CENTER" spacing="22" styleClass="right-panel" HBox.hgrow="ALWAYS">

            <Label fx:id="lbl" styleClass="login-heading" text="CREATE ACCOUNT">
                <font>
                    <Font size="20.0" />
                </font>
            </Label>

            <GridPane alignment="CENTER" hgap="12" vgap="14" maxWidth="400.0" styleClass="form-box">
                <columnConstraints>
                    <ColumnConstraints minWidth="110" halignment="RIGHT" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <MFXTextField fx:id="usernameField"
                              GridPane.rowIndex="0" GridPane.columnIndex="1"
                              alignment="CENTER_LEFT"
                              floatingText="Eg. ucc, no symbols/special characters"
                              prefWidth="250.0"
                              styleClass="mfx-text">
                    <font>
                        <Font size="13.0" />
                    </font>
                </MFXTextField>

                <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <MFXPasswordField fx:id="passwordField"
                                  GridPane.rowIndex="1" GridPane.columnIndex="1"
                                  alignment="CENTER_LEFT"
                                  floatingText="At least 6 characters"
                                  prefWidth="250.0"
                                  styleClass="mfx-text"
                                  textLimit="6">
                    <font>
                        <Font size="13.0" />
                    </font>
                </MFXPasswordField>

                <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <MFXTextField fx:id="emailField"
                              GridPane.rowIndex="2" GridPane.columnIndex="1"
                              alignment="CENTER_LEFT"
                              floatingText="Eg. lec@ucc.edu.gh"
                              prefWidth="250.0"
                              styleClass="mfx-text">
                    <font>
                        <Font size="13.0" />
                    </font>
                </MFXTextField>

                <Label text="MSISDN:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <MFXTextField fx:id="msisdnField"
                              GridPane.rowIndex="3" GridPane.columnIndex="1"
                              alignment="CENTER_LEFT"
                              floatingText="Eg. 0242123456"
                              prefWidth="250.0"
                              styleClass="mfx-text"
                              textLimit="12">
                    <font>
                        <Font size="13.0" />
                    </font>
                </MFXTextField>

                <HBox spacing="10"
                      alignment="CENTER_LEFT"
                      maxWidth="300.0"
                      GridPane.rowIndex="4"
                      GridPane.columnIndex="0"
                      GridPane.columnSpan="2">
                    <Label/>
                    <Label/>
                    <MFXButton fx:id="btnLogin" prefWidth="105.0" styleClass="mfx-button"
                               text="LOGIN" onAction="#onLoginBtnClick" />
                    <MFXButton fx:id="btnRegister" prefWidth="105.0" styleClass="mfx-button"
                               text="SUBMIT" onAction="#onRegisterBtnClick" />
                </HBox>
            </GridPane>

            <!-- Loading overlay, now correctly stacked above everything -->
            <VBox fx:id="loadingPane" alignment="CENTER" styleClass="loading-pane" visible="false">
                <ProgressIndicator fx:id="progressIndicator" />
                <Label style="-fx-text-fill: white;" text="Logging in..." />
            </VBox>
        </VBox>
    </HBox>

</StackPane>