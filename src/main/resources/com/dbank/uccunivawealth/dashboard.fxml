<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dbank.uccunivawealth.controller.DashboardController"
            styleClass="tab-scroll-pane">
    <VBox spacing="15" alignment="TOP_CENTER" styleClass="tab-content">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <HBox spacing="20" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <VBox styleClass="summary-card, card-savings" prefWidth="260" spacing="8" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                <Label text="Total Savings" styleClass="card-title"/>
                <Label fx:id="totalSavingsLabel" text="GHS 0.00" styleClass="card-value"/>
            </VBox>

            <VBox styleClass="summary-card, card-investment" prefWidth="260" spacing="8" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                <Label text="Total Investments" styleClass="card-title"/>
                <Label fx:id="totalInvestmentLabel" text="GHS 0.00" styleClass="card-value"/>
            </VBox>

            <VBox styleClass="summary-card, card-networth" prefWidth="260" spacing="8" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                <Label text="Net Worth" styleClass="card-title"/>
                <Label fx:id="netWorthLabel" text="GHS 0.00" styleClass="card-value"/>
            </VBox>
        </HBox>

        <PieChart fx:id="allocationChart" title="Asset Allocation" legendVisible="true" prefHeight="380"/>

        <MFXButton fx:id="refreshBtn" text="Refresh Dashboard" onAction="#onRefresh" styleClass="mfx-button-raised"/>
    </VBox>
</ScrollPane>
